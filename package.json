{
  "name": "agent-session-search",
  "productName": "Agent-Session-Search",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop console for searching, tagging, and resuming AI agent coding sessions.",
  "main": "out/main/index.js",
  "type": "module",
  "bin": {
    "agent-session-search": "bin/agent-session-search.cjs"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "files": [
    "out",
    "bin"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "electron-vite build"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "electron": "^35.0.0",
    "electron-store": "^10.0.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
