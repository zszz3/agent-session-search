{
  "name": "agent-session-search",
  "productName": "Agent-Session-Search",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop console for searching, tagging, and resuming AI agent coding sessions.",
  "license": "MIT",
  "main": "out/main/index.js",
  "type": "module",
  "bin": {
    "agent-session-search": "bin/agent-session-search.cjs",
    "agent-session-search-claude-statusline": "bin/claude-statusline-snapshot.cjs",
    "agent-session-search-setup-claude-statusline": "bin/setup-claude-statusline.cjs",
    "agent-session-search-skill-usage": "bin/skill-usage-record.cjs",
    "agent-session-search-setup-skill-usage-hook": "bin/setup-skill-usage-hook.cjs",
    "agent-session-search-mcp": "bin/agent-session-search-mcp.mjs",
    "agent-session-search-setup-mcp": "bin/setup-mcp.cjs"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "files": [
    "out",
    "bin",
    "assets"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && npm run build:mcp && electron-vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && npm run test:scripts",
    "test:scripts": "node --test scripts/*.test.mjs",
    "test:watch": "vitest",
    "release-note:check": "node scripts/release-notes.mjs check-range",
    "postinstall": "node bin/install-claude-statusline.cjs",
    "prepare": "npm run build:mcp && electron-vite build",
    "build:mcp": "node scripts/build-mcp-bundle.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron": "^42.3.0",
    "electron-store": "^10.0.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "esbuild": "^0.21.5"
  }
}
